# ENACT Protocol — Environment Configuration
# Copy to .env and fill in your values

# TON network
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=

# Wallet (24-word mnemonic, space-separated)
WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Deployed factory address
FACTORY_ADDRESS=EQAFHodWCzrYJTbrbJp1lMDQLfypTHoJCd0UcerjsdxPECjX

# Telegram bot (bot/ only)
BOT_TOKEN=123456:ABC-DEF

# MCP server (mcp-server/ only)
NETWORK=mainnet

# IPFS — for uploading job descriptions, results, and files.
# At least one of LIGHTHOUSE_API_KEY or PINATA_JWT must be set.
# When both are set, Lighthouse is primary with Pinata as fallback.
LIGHTHOUSE_API_KEY=
PINATA_JWT=

# Optional Agentic Wallet — alternative signer (no mnemonic in the agent).
# Mint at https://agents.ton.org. When set, MCP/plugin route through the
# operator key signing an ExternalSignedRequest (opcode 0xbf235204).
AGENTIC_WALLET_SECRET_KEY=
AGENTIC_WALLET_ADDRESS=

# AI Evaluator Agent (any OpenAI-compatible API: Groq, OpenRouter, Together)
GROQ_API_KEY=
