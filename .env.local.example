# Copy this file to .env.local (which is gitignored) and fill it in.
# Used by scripts/deploy-testnet-v2.ts and scripts/e2e-testnet-v2.ts.
#
# WALLET_MNEMONIC is your V5R1 24-word seed. Never commit a real seed.

WALLET_MNEMONIC="word1 word2 word3 ... word24"

# Optional — raises the testnet toncenter rate limit. Get a free key at
# https://t.me/tontestnetapibot for testnet, https://t.me/tonapibot for mainnet.
TONCENTER_API_KEY=

# Default endpoint is https://testnet.toncenter.com/api/v2/jsonRPC; override
# only if you run a custom RPC.
TONCENTER_ENDPOINT=
